{
  "filters": {},
  "rules": {
    "no-dead-link": {
      "checkRelative": true,
      "retry": 1,
      "ignore": [
        "https://stackoverflow.com/**",
        "https://softwareengineering.stackexchange.com/**",
        "http://**",
        "https://**"
      ],
      "ignoreRedirects": true
    }
  }
}